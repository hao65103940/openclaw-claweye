[Unit]
Description=Agent Monitor Platform API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/monitor-platform
ExecStart=/root/.nvm/versions/node/v24.13.0/bin/node server.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
